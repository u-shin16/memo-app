FLASK_ENV=development
MAX_CONTENT_LENGTH_MB=16

# Firebase Webアプリ設定（Firebaseコンソール > プロジェクトの設定 > マイアプリ）
# これらは秘密情報ではない（プロジェクトを識別するのみ）
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# Firebase Admin SDK サービスアカウント（バックエンドのトークン検証用）
# どちらか一方を設定:
# 1) JSON全体を1行の文字列としてここに設定（デプロイ環境向け）
FIREBASE_SERVICE_ACCOUNT_JSON=
# 2) または serviceAccountKey.json をプロジェクトルートに置く（ローカル開発向け、.gitignore対象）
# どちらも未設定の場合 /api/* は503を返す
