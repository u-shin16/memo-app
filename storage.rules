rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{uid}/media/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid
                    && request.resource.size < 100 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*|video/.*');
    }
  }
}
